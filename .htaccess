<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^robots\.txt$ public/index.php [L]

    # Serve the Laravel app from /public without forcing an external redirect.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
